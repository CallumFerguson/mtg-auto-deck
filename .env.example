# postgres database connection info
PGHOST=localhost
PGPORT=5432
PGDATABASE=
PGUSER=postgres
PGPASSWORD=

# LLM simulation runs
# LLM_PROVIDER must be openai or openrouter
LLM_PROVIDER=
LLM_STOP_WHEN_STEP_COUNT=

# OpenAI settings (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_REASONING_EFFORT=medium

# OpenRouter settings (used when LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5-nano
OPENROUTER_REASONING_EFFORT=medium

# OpenAI hosted MCP public URLs (used when LLM_PROVIDER=openai)
OPENING_HAND_MCP_PUBLIC_URL=
TURN_SIMULATION_MCP_PUBLIC_URL=
