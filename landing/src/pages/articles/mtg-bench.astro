---
const appBaseUrl = "https://app.mtgautodeck.com"
const signUpUrl = `${appBaseUrl}/sign-up`
const signInUrl = `${appBaseUrl}/sign-in`
const githubUrl = "https://github.com/CallumFerguson/mtg-auto-deck"
const contactEmail = "support@mtgautodeck.com"
const contactUrl = `mailto:${contactEmail}`
const title = "MTG Bench: Testing how well LLMs can play magic"
const date = "June 7, 2026"
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="MTG Bench tests how well LLMs can play Magic."
    />
    <meta name="theme-color" content="#0b1020" />
    <link rel="icon" type="image/svg+xml" href="/favicon.png" />
    <title>{title} | MTG Auto Deck</title>
  </head>
  <body>
    <header class="site-header" aria-label="Main navigation">
      <a class="brand" href="/" aria-label="MTG Auto Deck home">
        <img src="/favicon.png" alt="" width="32" height="32" />
        <span>MTG Auto Deck</span>
      </a>
      <nav class="nav-actions" aria-label="Account links">
        <a
          class="text-link github-link"
          href={githubUrl}
          aria-label="GitHub"
          target="_blank"
          rel="noreferrer"
        >
          <svg viewBox="0 0 16 16" aria-hidden="true">
            <path
              d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82A7.64 7.64 0 0 1 8 3.86c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
            />
          </svg>
        </a>
        <a class="text-link" href={signInUrl}>Log in</a>
        <a class="button button-secondary" href={signUpUrl}>Sign up</a>
      </nav>
    </header>

    <main class="article-page">
      <article class="article-shell" aria-labelledby="article-title">
        <h1 id="article-title">{title}</h1>
        <p class="article-date">{date}</p>

        <section class="benchmark-chart-section">
          <h2 class="benchmark-chart-heading">
            MTG Auto Deck score
            <span>(higher is better)</span>
          </h2>
          <div
            class="benchmark-score-chart benchmark-score-chart-loading"
            data-mtg-bench-score-chart
            role="group"
            aria-label="MTG Auto Deck benchmark scores"
            aria-busy="true"
          >
            <div
              class="benchmark-score-loading"
              role="status"
              aria-live="polite"
            >
              <span class="benchmark-score-spinner" aria-hidden="true"></span>
              <span>Loading benchmark results...</span>
            </div>
          </div>
        </section>

        <section class="benchmark-chart-section">
          <h2 class="benchmark-chart-heading">
            Reasoning tokens per turn
            <span>(lower is better)</span>
          </h2>
          <div
            class="benchmark-score-chart benchmark-score-chart-loading"
            data-mtg-bench-reasoning-chart
            role="group"
            aria-label="Reasoning tokens per turn by benchmark, lower is better"
            aria-busy="true"
          >
            <div
              class="benchmark-score-loading"
              role="status"
              aria-live="polite"
            >
              <span class="benchmark-score-spinner" aria-hidden="true"></span>
              <span>Loading benchmark results...</span>
            </div>
          </div>
        </section>

        <section class="benchmark-chart-section">
          <h2 class="benchmark-chart-heading">
            Cost per attempted turn vs score
          </h2>
          <div
            class="benchmark-scatter-chart benchmark-score-chart-loading"
            data-mtg-bench-cost-score-chart
            role="group"
            aria-label="Cost per attempted turn from $0.00 to $0.20 versus MTG Auto Deck score from 0 to 100"
            aria-busy="true"
          >
            <div
              class="benchmark-score-loading"
              role="status"
              aria-live="polite"
            >
              <span class="benchmark-score-spinner" aria-hidden="true"></span>
              <span>Loading benchmark results...</span>
            </div>
          </div>
        </section>

        <div class="article-body">
          <p>
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse
            potenti. Integer vitae neque vel justo placerat bibendum. Donec
            dictum, sem sed efficitur gravida, justo lorem pulvinar tortor, at
            viverra sapien augue nec lectus.
          </p>
          <p>
            Praesent porttitor risus non lorem fermentum, sit amet dignissim
            metus aliquam. Curabitur congue, nisl at finibus sodales, magna sem
            tempor lacus, vitae pretium mi lectus in lorem. Sed at velit quis
            urna luctus hendrerit.
          </p>
          <p>
            Maecenas consequat, magna et aliquam faucibus, est erat faucibus
            risus, non porta erat turpis sed ipsum. Aliquam erat volutpat. Duis
            sit amet ipsum a sem ultricies posuere vitae in lacus.
          </p>
        </div>
      </article>
    </main>

    <footer class="site-footer" aria-label="Footer">
      <div class="footer-content">
        <a class="text-link footer-brand" href="/">MTG Auto Deck</a>
        <a
          class="text-link"
          href={contactUrl}>{contactEmail}</a
        >
      </div>
    </footer>
  </body>
</html>

<script>
  type MtgBenchResultEntry = {
    benchmarkId: string
    url: string
    data: unknown
  }

  type MtgBenchResultsState =
    | {
        status: "loading"
        benchmarkIds: string[]
      }
    | {
        status: "loaded"
        benchmarkIds: string[]
        results: MtgBenchResultEntry[]
        resultsByBenchmarkId: Record<string, MtgBenchResultEntry>
        loadedAt: string
      }
    | {
        status: "error"
        benchmarkIds: string[]
        error: {
          message: string
        }
      }

  type MtgBenchMetricBar = {
    benchmarkId: string
    labelLineOne: string
    labelLineTwo: string
    metricAriaLabel: string
    providerMatch: MtgBenchProviderMatch | null
    value: number | null
    valueLabel: string
    heightPercent: number
  }

  type MtgBenchScatterPoint = {
    benchmarkId: string
    costPerAttemptedTurn: number
    score: number
    providerMatch: MtgBenchProviderMatch | null
  }

  type MtgBenchProviderMatch = {
    barColor: string
    barTextColor: string
    logoAlt: string
    logoSrc: string
  }

  const mtgBenchProviderMatches: Record<string, MtgBenchProviderMatch> = {
    alibaba: {
      barColor: "#FF7018",
      barTextColor: "#ffffff",
      logoAlt: "Alibaba",
      logoSrc: "/alibaba_small.svg",
    },
    anthropic: {
      barColor: "#CC785C",
      barTextColor: "#ffffff",
      logoAlt: "Anthropic",
      logoSrc: "/anthropic-1.svg",
    },
    deepseek: {
      barColor: "#2243E6",
      barTextColor: "#ffffff",
      logoAlt: "DeepSeek",
      logoSrc: "/deepseek_small.svg",
    },
    google: {
      barColor: "#4890E5",
      barTextColor: "#ffffff",
      logoAlt: "Google",
      logoSrc: "/google_small.svg",
    },
    moonshotai: {
      barColor: "#047AFE",
      barTextColor: "#ffffff",
      logoAlt: "Kimi",
      logoSrc: "/kimi_small.png",
    },
    openai: {
      barColor: "#10A37F",
      barTextColor: "#ffffff",
      logoAlt: "OpenAI",
      logoSrc: "/openai_small.svg",
    },
    xai: {
      barColor: "#736CD3",
      barTextColor: "#ffffff",
      logoAlt: "xAI",
      logoSrc: "/xai.svg",
    },
  }
  const mtgBenchProviderAliases: Record<string, string> = {
    qwen: "alibaba",
    "x-ai": "xai",
  }

  const mtgBenchResultsBaseUrl = "https://data.mtgautodeck.com/benchmarks"
  const mtgBenchPublicBenchmarkBaseUrl =
    "https://app.mtgautodeck.com/public/benchmarks"
  const mtgBenchScatterMaxCostUsd = 0.2
  const mtgBenchScatterCostTicks = [0, 0.05, 0.1, 0.15, 0.2]
  const mtgBenchScatterScoreTicks = [0, 25, 50, 75, 100]
  const mtgBenchBenchmarkIds = [
    "23c6ab87-5419-4bfd-a281-740b2384a5b8",
    "3947a331-f7c9-4697-abda-a8b6ccf9a91f",
    "2f984f51-3a2f-45db-b87b-ed7edfea8027",
    "79d1ed51-ca1d-4783-a71c-66e46af6e718",
    "4bd9955b-ebe1-4fe1-bb87-52d5111c4025",
    "6349dda2-4069-4825-971e-8c11234260c4",
    "c289c85f-051f-43d2-a9d0-5cddabb0d8f4",
    "b7403939-7686-4b2a-88ab-92208ff80220",
    "0b5b448b-d276-461b-85ea-542593639e35",
    "c36e6599-dccc-4e4d-86cd-3b5fc5b4497e",
    "9c7fee4d-9408-4dca-b1e2-50879fa45a1e",
    "dcc18bd8-339d-458a-a94d-28385ca525c7",
    "ef00418d-ab60-4efb-94a1-2756ae2a6348",
  ]
  const mtgBenchWindow = window as Window & {
    mtgBenchResults: MtgBenchResultsState
  }
  const mtgBenchScoreChart = document.querySelector<HTMLElement>(
    "[data-mtg-bench-score-chart]"
  )
  const mtgBenchReasoningChart = document.querySelector<HTMLElement>(
    "[data-mtg-bench-reasoning-chart]"
  )
  const mtgBenchCostScoreChart = document.querySelector<HTMLElement>(
    "[data-mtg-bench-cost-score-chart]"
  )

  mtgBenchWindow.mtgBenchResults = {
    status: "loading",
    benchmarkIds: [...mtgBenchBenchmarkIds],
  }

  void loadMtgBenchResults()

  async function loadMtgBenchResults() {
    try {
      const results = await Promise.all(
        mtgBenchBenchmarkIds.map(fetchMtgBenchResult)
      )
      const resultsByBenchmarkId = Object.fromEntries(
        results.map((result) => [result.benchmarkId, result])
      )

      mtgBenchWindow.mtgBenchResults = {
        status: "loaded",
        benchmarkIds: [...mtgBenchBenchmarkIds],
        results,
        resultsByBenchmarkId,
        loadedAt: new Date().toISOString(),
      }
      renderMtgBenchMetricChart(
        mtgBenchScoreChart,
        buildMtgBenchScoreBars(results)
      )
      renderMtgBenchMetricChart(
        mtgBenchReasoningChart,
        buildMtgBenchReasoningTokenBars(results)
      )
      renderMtgBenchScatterChart(
        mtgBenchCostScoreChart,
        buildMtgBenchCostScorePoints(results)
      )
    } catch (error) {
      const message =
        error instanceof Error
          ? error.message
          : "Benchmark results could not be loaded."

      mtgBenchWindow.mtgBenchResults = {
        status: "error",
        benchmarkIds: [...mtgBenchBenchmarkIds],
        error: {
          message,
        },
      }
      renderMtgBenchMetricChart(mtgBenchScoreChart, [])
      renderMtgBenchMetricChart(mtgBenchReasoningChart, [])
      renderMtgBenchScatterChart(mtgBenchCostScoreChart, [])
      window.alert("Benchmark results could not be loaded. Please try again.")
    }
  }

  async function fetchMtgBenchResult(
    benchmarkId: string
  ): Promise<MtgBenchResultEntry> {
    const url = `${mtgBenchResultsBaseUrl}/${encodeURIComponent(
      benchmarkId
    )}/results.json`
    const response = await fetch(url)

    if (!response.ok) {
      throw new Error(
        `Benchmark results request failed for ${benchmarkId}: ${response.status} ${response.statusText}`
      )
    }

    return {
      benchmarkId,
      url,
      data: await response.json(),
    }
  }

  function buildMtgBenchScoreBars(results: readonly MtgBenchResultEntry[]) {
    return results
      .map((result) => {
        const labelLines = buildMtgBenchLabelLines(
          getMtgBenchModelLabel(result.data),
          getMtgBenchReasoningEffortLabel(result.data)
        )

        return {
          benchmarkId: result.benchmarkId,
          labelLineOne: labelLines[0],
          labelLineTwo: labelLines[1],
          metricAriaLabel: "MTG Auto Deck score, higher is better",
          providerMatch: getMtgBenchProviderMatch(result.data),
          value: getMtgBenchScore(result.data),
          valueLabel: formatMtgBenchBarScore(getMtgBenchScore(result.data)),
          heightPercent: Math.max(
            0,
            Math.min(getMtgBenchScore(result.data) ?? 0, 100)
          ),
        }
      })
      .sort(compareMtgBenchScoreBars)
  }

  function buildMtgBenchReasoningTokenBars(
    results: readonly MtgBenchResultEntry[]
  ) {
    const maxReasoningTokens = Math.max(
      0,
      ...results
        .map((result) => getMtgBenchReasoningTokensPerTurn(result.data))
        .filter((value): value is number => value !== null)
    )

    return results
      .map((result) => {
        const reasoningTokens = getMtgBenchReasoningTokensPerTurn(result.data)
        const labelLines = buildMtgBenchLabelLines(
          getMtgBenchModelLabel(result.data),
          getMtgBenchReasoningEffortLabel(result.data)
        )

        return {
          benchmarkId: result.benchmarkId,
          labelLineOne: labelLines[0],
          labelLineTwo: labelLines[1],
          metricAriaLabel: "Reasoning tokens per turn, lower is better",
          providerMatch: getMtgBenchProviderMatch(result.data),
          value: reasoningTokens,
          valueLabel: formatMtgBenchBarTokenRate(reasoningTokens),
          heightPercent:
            maxReasoningTokens > 0 && reasoningTokens !== null
              ? (reasoningTokens / maxReasoningTokens) * 100
              : 0,
        }
      })
      .sort(compareMtgBenchReasoningTokenBars)
  }

  function buildMtgBenchCostScorePoints(
    results: readonly MtgBenchResultEntry[]
  ) {
    return results.flatMap((result) => {
      const costPerAttemptedTurn = getMtgBenchCostPerAttemptedTurn(result.data)
      const score = getMtgBenchScore(result.data)

      if (costPerAttemptedTurn === null || score === null) {
        return []
      }

      return [
        {
          benchmarkId: result.benchmarkId,
          costPerAttemptedTurn,
          score,
          providerMatch: getMtgBenchProviderMatch(result.data),
        },
      ]
    })
  }

  function compareMtgBenchScoreBars(
    first: MtgBenchMetricBar,
    second: MtgBenchMetricBar
  ) {
    const firstScore = first.value ?? Number.NEGATIVE_INFINITY
    const secondScore = second.value ?? Number.NEGATIVE_INFINITY
    const scoreCompare = secondScore - firstScore

    return scoreCompare || first.benchmarkId.localeCompare(second.benchmarkId)
  }

  function compareMtgBenchReasoningTokenBars(
    first: MtgBenchMetricBar,
    second: MtgBenchMetricBar
  ) {
    const firstTokens = first.value ?? Number.POSITIVE_INFINITY
    const secondTokens = second.value ?? Number.POSITIVE_INFINITY
    const tokenCompare = firstTokens - secondTokens

    return tokenCompare || first.benchmarkId.localeCompare(second.benchmarkId)
  }

  function renderMtgBenchMetricChart(
    chart: HTMLElement | null,
    metricBars: readonly MtgBenchMetricBar[]
  ) {
    if (!chart) {
      return
    }

    chart.classList.remove("benchmark-score-chart-loading")
    chart.removeAttribute("aria-busy")
    chart.replaceChildren(
      ...metricBars.map((metricBar) => {
        const column = document.createElement("a")
        const plot = document.createElement("div")
        const bar = document.createElement("div")
        const logoSlot = document.createElement("div")
        const label = document.createElement("div")
        const labelText = document.createElement("div")
        const modelLabel = document.createElement("span")
        const reasoningEffortLabel = document.createElement("span")

        column.className = "benchmark-score-column"
        column.href = `${mtgBenchPublicBenchmarkBaseUrl}/${encodeURIComponent(
          metricBar.benchmarkId
        )}`
        column.rel = "noreferrer noopener"
        column.target = "_blank"
        column.setAttribute(
          "aria-label",
          `Open benchmark ${metricBar.labelLineOne} ${metricBar.labelLineTwo}, ${metricBar.metricAriaLabel} ${metricBar.valueLabel}`
        )
        plot.className = "benchmark-score-plot"
        bar.className = "benchmark-score-bar"
        bar.style.height = `${Math.max(
          0,
          Math.min(metricBar.heightPercent, 100)
        )}%`
        if (metricBar.providerMatch) {
          bar.style.backgroundColor = metricBar.providerMatch.barColor
          bar.style.color = metricBar.providerMatch.barTextColor
        }
        bar.textContent = metricBar.valueLabel
        bar.setAttribute(
          "aria-label",
          `${metricBar.metricAriaLabel} ${metricBar.valueLabel}`
        )
        logoSlot.className = "benchmark-score-logo-slot"
        if (metricBar.providerMatch) {
          const logo = document.createElement("img")

          logo.alt = metricBar.providerMatch.logoAlt
          logo.className = "benchmark-score-logo"
          logo.decoding = "async"
          logo.loading = "lazy"
          logo.src = metricBar.providerMatch.logoSrc
          logoSlot.append(logo)
        }
        label.className = "benchmark-score-label"
        labelText.className = "benchmark-score-label-text"
        modelLabel.textContent = metricBar.labelLineOne
        reasoningEffortLabel.textContent = metricBar.labelLineTwo

        labelText.append(modelLabel, reasoningEffortLabel)
        label.append(labelText)
        plot.append(bar)
        column.append(plot, logoSlot, label)

        return column
      })
    )
  }

  function renderMtgBenchScatterChart(
    chart: HTMLElement | null,
    points: readonly MtgBenchScatterPoint[]
  ) {
    if (!chart) {
      return
    }

    const layout = document.createElement("div")
    const plot = document.createElement("div")
    const pointLayer = document.createElement("div")
    const yAxisLabel = document.createElement("span")
    const xAxisLabel = document.createElement("span")
    const yTickLabels = mtgBenchScatterScoreTicks.map((tick) => {
      const tickLabel = document.createElement("span")

      tickLabel.className =
        "benchmark-scatter-axis-label benchmark-scatter-y-tick"
      tickLabel.style.bottom = `${getMtgBenchScatterScorePercent(tick)}%`
      tickLabel.textContent = String(tick)

      return tickLabel
    })
    const xTickLabels = mtgBenchScatterCostTicks.map((tick) => {
      const tickLabel = document.createElement("span")

      tickLabel.className =
        "benchmark-scatter-axis-label benchmark-scatter-x-tick"
      tickLabel.style.left = `${getMtgBenchScatterCostPercent(tick)}%`
      tickLabel.textContent = formatMtgBenchScatterCostTick(tick)

      return tickLabel
    })

    layout.className = "benchmark-scatter-layout"
    plot.className = "benchmark-scatter-plot"
    pointLayer.className = "benchmark-scatter-point-layer"
    yAxisLabel.className =
      "benchmark-scatter-axis-title benchmark-scatter-y-title"
    xAxisLabel.className =
      "benchmark-scatter-axis-title benchmark-scatter-x-title"
    yAxisLabel.textContent = "MTG Auto Deck score"
    xAxisLabel.textContent = "Cost per attempted turn (USD)"

    pointLayer.append(
      ...points.map((point) => {
        const dot = document.createElement("span")

        dot.className = "benchmark-scatter-point"
        dot.setAttribute("aria-hidden", "true")
        dot.style.left = `${getMtgBenchScatterCostPercent(
          point.costPerAttemptedTurn
        )}%`
        dot.style.bottom = `${getMtgBenchScatterScorePercent(point.score)}%`
        dot.style.backgroundColor =
          point.providerMatch?.barColor ?? "var(--accent-strong)"

        return dot
      })
    )
    plot.append(pointLayer, ...yTickLabels, ...xTickLabels, xAxisLabel)
    layout.append(yAxisLabel, plot)

    chart.classList.remove("benchmark-score-chart-loading")
    chart.removeAttribute("aria-busy")
    chart.replaceChildren(layout)
  }

  function getMtgBenchScore(data: unknown) {
    if (!isRecord(data) || !isRecord(data.resultMetrics)) {
      return null
    }

    const score = data.resultMetrics.mtgAutoDeckScore

    return typeof score === "number" && Number.isFinite(score) ? score : null
  }

  function getMtgBenchReasoningTokensPerTurn(data: unknown) {
    if (!isRecord(data) || !isRecord(data.resultMetrics)) {
      return null
    }

    const reasoningTokens = data.resultMetrics.reasoningTokensPerAttemptedTurn

    return typeof reasoningTokens === "number" &&
      Number.isFinite(reasoningTokens)
      ? reasoningTokens
      : null
  }

  function getMtgBenchCostPerAttemptedTurn(data: unknown) {
    if (!isRecord(data) || !isRecord(data.resultMetrics)) {
      return null
    }

    const costPerAttemptedTurn = data.resultMetrics.costPerAttemptedTurn

    if (
      typeof costPerAttemptedTurn !== "number" ||
      !Number.isFinite(costPerAttemptedTurn)
    ) {
      return null
    }

    return isMtgBenchDiscountedCost(data)
      ? roundMtgBenchDisplayCost(costPerAttemptedTurn * 2)
      : costPerAttemptedTurn
  }

  function isMtgBenchDiscountedCost(data: unknown) {
    if (!isRecord(data) || !isRecord(data.benchmark)) {
      return false
    }

    const llmProcessingMode = data.benchmark.llmProcessingMode

    if (
      typeof llmProcessingMode === "string" &&
      llmProcessingMode !== "realtime"
    ) {
      return true
    }

    return data.benchmark.useFlexServiceTier === true
  }

  function getMtgBenchProviderMatch(data: unknown) {
    const providerKey = getMtgBenchProviderKey(data)

    return providerKey ? (mtgBenchProviderMatches[providerKey] ?? null) : null
  }

  function getMtgBenchProviderKey(data: unknown) {
    if (!isRecord(data) || !isRecord(data.benchmark)) {
      return null
    }

    const provider = data.benchmark.llmModelPresetProvider

    if (typeof provider !== "string") {
      return null
    }

    const normalizedProvider = normalizeMtgBenchProviderKey(provider)

    if (normalizedProvider !== "openrouter") {
      return normalizedProvider
    }

    const model = data.benchmark.llmModelPresetModel

    if (typeof model !== "string") {
      return normalizedProvider
    }

    const modelProvider = model.trim().split("/")[0]

    return normalizeMtgBenchProviderKey(modelProvider) || normalizedProvider
  }

  function normalizeMtgBenchProviderKey(provider: string) {
    const normalizedProvider = provider.trim().toLowerCase()

    return mtgBenchProviderAliases[normalizedProvider] ?? normalizedProvider
  }

  function getMtgBenchModelLabel(data: unknown) {
    if (!isRecord(data) || !isRecord(data.benchmark)) {
      return "-"
    }

    const model = data.benchmark.llmModelPresetModel

    if (typeof model !== "string") {
      return "-"
    }

    const trimmedModel = model.trim()

    if (!trimmedModel) {
      return "-"
    }

    const slashIndex = trimmedModel.indexOf("/")
    const modelWithoutProvider =
      slashIndex === -1 ? trimmedModel : trimmedModel.slice(slashIndex + 1)

    return modelWithoutProvider.trim() || trimmedModel
  }

  function getMtgBenchReasoningEffortLabel(data: unknown) {
    if (!isRecord(data) || !isRecord(data.benchmark)) {
      return "-"
    }

    const reasoningEffort = data.benchmark.llmModelPresetReasoningEffort

    return typeof reasoningEffort === "string" && reasoningEffort.trim()
      ? reasoningEffort.trim().replaceAll("_", " ")
      : "-"
  }

  function buildMtgBenchLabelLines(
    modelLabel: string,
    reasoningEffortLabel: string
  ): [string, string] {
    const modelSplit = getMtgBenchModelLabelSplit(modelLabel)

    if (!modelSplit) {
      return [modelLabel, reasoningEffortLabel]
    }

    return [
      modelSplit[0],
      [modelSplit[1], reasoningEffortLabel].filter(Boolean).join(" "),
    ]
  }

  function getMtgBenchModelLabelSplit(modelLabel: string) {
    if (modelLabel.length < 16) {
      return null
    }

    const preferredDashIndex = modelLabel.lastIndexOf("-", 15)
    const dashIndex =
      preferredDashIndex === -1
        ? modelLabel.indexOf("-")
        : preferredDashIndex

    if (dashIndex === -1 || dashIndex === modelLabel.length - 1) {
      return null
    }

    return [
      modelLabel.slice(0, dashIndex + 1),
      modelLabel.slice(dashIndex + 1),
    ] as const
  }

  function formatMtgBenchBarScore(score: number | null) {
    return score === null ? "-" : score.toFixed(1).replace(/\.0$/u, "")
  }

  function formatMtgBenchBarTokenRate(tokenRate: number | null) {
    return tokenRate === null ? "-" : `${(tokenRate / 1000).toFixed(1)}K`
  }

  function getMtgBenchScatterCostPercent(costPerAttemptedTurn: number) {
    return clampMtgBenchPercent(
      (costPerAttemptedTurn / mtgBenchScatterMaxCostUsd) * 100
    )
  }

  function getMtgBenchScatterScorePercent(score: number) {
    return clampMtgBenchPercent(score)
  }

  function clampMtgBenchPercent(percent: number) {
    return Math.round(Math.max(0, Math.min(percent, 100)) * 1000) / 1000
  }

  function formatMtgBenchScatterCostTick(costUsd: number) {
    return `$${costUsd.toFixed(2)}`
  }

  function roundMtgBenchDisplayCost(costUsd: number) {
    return Math.round(costUsd * 1_000_000_000) / 1_000_000_000
  }

  function isRecord(value: unknown): value is Record<string, unknown> {
    return Boolean(value) && typeof value === "object" && !Array.isArray(value)
  }
</script>

