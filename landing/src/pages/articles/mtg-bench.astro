---
const appBaseUrl = "https://app.mtgautodeck.com"
const signUpUrl = `${appBaseUrl}/sign-up`
const signInUrl = `${appBaseUrl}/sign-in`
const githubUrl = "https://github.com/CallumFerguson/mtg-auto-deck"
const contactEmail = "support@mtgautodeck.com"
const contactUrl = `mailto:${contactEmail}`
const title = "MTG Bench : Testing how well LLMs can play magic"
const date = "June 7, 2026"
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="MTG Bench tests how well LLMs can play Magic."
    />
    <meta name="theme-color" content="#0b1020" />
    <link rel="icon" type="image/svg+xml" href="/favicon.png" />
    <title>{title} | MTG Auto Deck</title>
  </head>
  <body>
    <header class="site-header" aria-label="Main navigation">
      <a class="brand" href="/" aria-label="MTG Auto Deck home">
        <img src="/favicon.png" alt="" width="32" height="32" />
        <span>MTG Auto Deck</span>
      </a>
      <nav class="nav-actions" aria-label="Account links">
        <a
          class="text-link github-link"
          href={githubUrl}
          aria-label="GitHub"
          target="_blank"
          rel="noreferrer"
        >
          <svg viewBox="0 0 16 16" aria-hidden="true">
            <path
              d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82A7.64 7.64 0 0 1 8 3.86c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
            />
          </svg>
        </a>
        <a class="text-link" href={signInUrl}>Log in</a>
        <a class="button button-secondary" href={signUpUrl}>Sign up</a>
      </nav>
    </header>

    <main class="article-page">
      <article class="article-shell" aria-labelledby="article-title">
        <h1 id="article-title">{title}</h1>
        <p class="article-date">{date}</p>

        <div class="article-body">
          <p>
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse
            potenti. Integer vitae neque vel justo placerat bibendum. Donec
            dictum, sem sed efficitur gravida, justo lorem pulvinar tortor, at
            viverra sapien augue nec lectus.
          </p>
          <p>
            Praesent porttitor risus non lorem fermentum, sit amet dignissim
            metus aliquam. Curabitur congue, nisl at finibus sodales, magna sem
            tempor lacus, vitae pretium mi lectus in lorem. Sed at velit quis
            urna luctus hendrerit.
          </p>
          <p>
            Maecenas consequat, magna et aliquam faucibus, est erat faucibus
            risus, non porta erat turpis sed ipsum. Aliquam erat volutpat. Duis
            sit amet ipsum a sem ultricies posuere vitae in lacus.
          </p>
        </div>
      </article>
    </main>

    <footer class="site-footer" aria-label="Footer">
      <div class="footer-content">
        <a class="text-link footer-brand" href="/">MTG Auto Deck</a>
        <a
          class="text-link"
          href={contactUrl}>{contactEmail}</a
        >
      </div>
    </footer>
  </body>
</html>

<style>
  :root {
    color-scheme: dark;
    --bg: #0b1020;
    --bg-deep: #05070d;
    --surface: #101827;
    --surface-raised: #151f31;
    --text: #f8fafc;
    --muted: #aeb8c7;
    --subtle: #7d8ca1;
    --border: rgba(226, 232, 240, 0.14);
    --border-strong: rgba(125, 211, 252, 0.38);
    --accent: #38bdf8;
    --accent-strong: #7dd3fc;
    --accent-dark: #0f3d5a;
    --green: #6ee7b7;
    --amber: #f8c471;
    --shadow: rgba(0, 0, 0, 0.45);
    font-family:
      Inter,
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg-deep);
    scroll-behavior: smooth;
  }

  body {
    min-width: 320px;
    margin: 0;
    background: var(--bg-deep);
    color: var(--text);
    font-family: inherit;
    line-height: 1.5;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
  }

  body::selection {
    background: rgba(56, 189, 248, 0.3);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    max-width: 100%;
  }

  .site-header {
    position: absolute;
    inset: 0 0 auto;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: min(1280px, calc(100% - 32px));
    margin: 0 auto;
    padding: 1rem 0;
  }

  .brand,
  .nav-actions {
    display: flex;
    align-items: center;
  }

  .brand {
    gap: 0.7rem;
    min-width: 0;
    font-weight: 800;
    letter-spacing: 0;
  }

  .brand img {
    flex: 0 0 auto;
  }

  .brand span {
    color: var(--accent-strong);
    font-size: 0.9rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    overflow-wrap: anywhere;
  }

  .nav-actions {
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .text-link {
    color: var(--muted);
    font-size: 0.95rem;
    font-weight: 700;
  }

  .text-link:hover {
    color: var(--text);
  }

  .github-link {
    display: inline-flex;
    min-height: 2.35rem;
    width: 2.35rem;
    align-items: center;
    justify-content: center;
  }

  .github-link svg {
    width: 1.25rem;
    height: 1.25rem;
    fill: currentColor;
  }

  .button {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    justify-content: center;
    border: 1px solid transparent;
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    font-weight: 800;
    line-height: 1;
    text-align: center;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background 160ms ease,
      color 160ms ease;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button-secondary {
    border-color: rgba(125, 211, 252, 0.32);
    background: rgba(15, 61, 90, 0.7);
    color: var(--text);
  }

  .button-secondary:hover {
    border-color: var(--accent-strong);
    background: rgba(15, 61, 90, 0.95);
  }

  .site-footer {
    border-top: 1px solid var(--border);
    background: var(--bg-deep);
    color: var(--muted);
  }

  .footer-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: min(1280px, calc(100% - 32px));
    margin: 0 auto;
    padding: 1.25rem 0;
    font-size: 0.92rem;
    font-weight: 700;
  }

  .footer-brand {
    color: var(--subtle);
  }

  .article-page {
    min-height: 100vh;
    padding: 7.75rem 1rem 5rem;
    background: var(--bg-deep);
  }

  .article-shell {
    width: min(760px, calc(100% - 32px));
    margin: 0 auto;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    background: var(--surface);
    padding: clamp(1.35rem, 4vw, 3rem);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.2);
  }

  h1,
  p {
    overflow-wrap: break-word;
  }

  h1 {
    max-width: 640px;
    margin: 0;
    font-size: clamp(1.9rem, 5vw, 2.8rem);
    letter-spacing: 0;
    line-height: 1.08;
  }

  .article-date {
    margin: 0.85rem 0 0;
    color: var(--subtle);
    font-size: 0.92rem;
    font-weight: 700;
  }

  .article-body {
    display: grid;
    gap: 1.15rem;
    margin-top: 2.5rem;
  }

  .article-body p {
    margin: 0;
    color: var(--muted);
    font-size: 1.02rem;
    line-height: 1.75;
  }

  @media (max-width: 620px) {
    .site-header {
      align-items: flex-start;
    }

    .brand span {
      max-width: 8.5rem;
      line-height: 1.1;
    }

    .nav-actions {
      gap: 0.55rem;
    }

    .text-link {
      min-height: 2.35rem;
      display: inline-flex;
      align-items: center;
    }

    .button {
      width: 100%;
    }

    .nav-actions .button {
      width: auto;
      padding-inline: 0.8rem;
    }

    .footer-content {
      width: min(100% - 28px, 1280px);
    }

    .article-page {
      padding: 7rem 0 4rem;
    }

    .article-shell {
      width: min(100% - 28px, 760px);
      padding: 1.35rem;
    }

    .article-date {
      font-size: 0.9rem;
    }
  }
</style>
